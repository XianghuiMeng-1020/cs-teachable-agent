# CS Teachable Agent — environment template
# Copy to .env and fill in at least one LLM key for teaching/dialogue/code generation.

# Optional: OpenAI (GPT-4o-mini or gpt-4o). Used first if set.
OPENAI_API_KEY=sk-...

# Optional: DeepSeek (OpenAI-compatible API). Used if OPENAI_API_KEY is not set.
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# Optional: JWT secret for auth (defaults to dev secret if unset).
# SECRET_KEY=your-random-secret

# Optional: Database URL (defaults to SQLite in project root).
# DATABASE_URL=sqlite:///./teachable_agent.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/teachable_agent
